# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, but keep the example template in the repo
.env*
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# SQLite DB (do not commit user data)
db/*.db
db/*.db-journal

# User uploads (payment screenshots, KYC docs)
public/uploads/kyc/*
public/uploads/payments/*
!public/uploads/.gitkeep

# Sensitive uploads now live outside public/ — never commit user PII
/private_uploads/

# Admin-uploaded customer videos (public marketing content)
/public/reels/

# Admin-uploaded Android APK
/public/downloads/

# Source/personal assets — not needed at runtime, keep off the public repo
/assets/

# Build artifacts / packaged bundles
*.zip

# Internal deploy notes (contain live server IP + credentials — keep out of the repo)
/DEPLOY-HOSTBREAK.md
/docs/DEPLOY-SUPERADMIN.md
