# Smart Qarz — environment configuration (copy to .env and fill in)

# --- Database (PostgreSQL) --------------------------------------------------
# The app uses PostgreSQL (provider = "postgresql" in prisma/schema.prisma).
# On Vercel: create a Postgres DB (Vercel Postgres / Neon / Supabase) and use its
# POOLED connection string. Example:
#   DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# For local dev, point this at a local or cloud (e.g. Neon) Postgres instance.
DATABASE_URL=

# --- File storage (Vercel Blob) --------------------------------------------
# Sensitive uploads (KYC docs, payment screenshots) + public assets (customer
# reels, APK) are stored in Vercel Blob when this token is present. Create a Blob
# store in the Vercel dashboard → Storage → Blob, then copy its read/write token.
# When UNSET, the app falls back to local-disk storage (dev / self-hosted only).
BLOB_READ_WRITE_TOKEN=

# Secret used to sign session cookies (HMAC). REQUIRED in production (min 16 chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Local-disk fallback for sensitive uploads (used only when BLOB_READ_WRITE_TOKEN
# is unset). MUST be a writable path OUTSIDE the public web root.
UPLOADS_DIR=./private_uploads

# Optional: initial admin password used only when seeding a fresh DB.
# ADMIN_INITIAL_PASSWORD=change-me-strong

# --- Super Admin (optional, top-level control panel at /superadmin) ---
# Credentials live ONLY here, never in source. Leave unset to disable the super admin.
# SUPERADMIN_PHONE=03xxxxxxxxx
# Preferred: store a BCRYPT HASH, not the plaintext. Generate one:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'YourStrongPassword'
# NOTE: a bcrypt hash contains '$'. In a .env FILE escape each '$' as '\$'. NOT needed
# when set directly in the host's env-var UI (Vercel / cPanel / systemd).
# SUPERADMIN_PASSWORD_HASH=\$2a\$10\$....
# SUPERADMIN_PASSWORD=YourStrongPassword
